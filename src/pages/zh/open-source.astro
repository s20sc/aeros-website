---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="开源生态 — AEROS" description="AEROS 运行时核心和 ECM 包管理系统以 Apache 2.0 开源。" lang="zh">

  <section class="section" style="padding-bottom: var(--space-2xl);">
    <div class="container">
      <div class="section-label">开源生态</div>
      <h1 class="page-title">在开放中构建</h1>
      <p class="page-desc">
        AEROS 运行时核心和 ECM 包管理系统采用 Apache 2.0 许可。
        使用它、复刻它、为它贡献代码。
      </p>
    </div>
  </section>

  <!-- ═══ Repositories ═══ -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-label">代码仓库</div>
      <h2 class="section-title">源代码</h2>

      <div class="repo-grid">
        <a href="https://github.com/s20sc/aeros-runtime" target="_blank" rel="noopener" class="repo-card">
          <div class="repo-header">
            <span class="repo-name">s20sc/aeros-runtime</span>
            <span class="repo-license">Apache 2.0</span>
          </div>
          <p class="repo-desc">运行时核心 + ECM 系统 + MVP 演示。主仓库。</p>
          <div class="repo-tags">
            <span>Python</span>
            <span>asyncio</span>
            <span>runtime</span>
          </div>
        </a>

        <a href="https://s20sc.github.io/aeros-project" target="_blank" rel="noopener" class="repo-card">
          <div class="repo-header">
            <span class="repo-name">s20sc/aeros-project</span>
            <span class="repo-license">Research</span>
          </div>
          <p class="repo-desc">学术项目主页，包含全部 7 篇论文和研究文档。</p>
          <div class="repo-tags">
            <span>Papers</span>
            <span>arXiv</span>
          </div>
        </a>

        <div class="repo-card repo-planned">
          <div class="repo-header">
            <span class="repo-name">s20sc/aeros-contracts</span>
            <span class="repo-license repo-soon">计划中</span>
          </div>
          <p class="repo-desc">契约引擎 CLI — 验证、测试和管理能力契约。</p>
          <div class="repo-tags">
            <span>CLI</span>
            <span>contracts</span>
          </div>
        </div>

        <div class="repo-card repo-planned">
          <div class="repo-header">
            <span class="repo-name">s20sc/aeros-bench</span>
            <span class="repo-license repo-soon">计划中</span>
          </div>
          <p class="repo-desc">EmbodiedGovBench — 受治理具身智能体系统的基准测试套件。</p>
          <div class="repo-tags">
            <span>Benchmark</span>
            <span>evaluation</span>
          </div>
        </div>

        <div class="repo-card repo-planned">
          <div class="repo-header">
            <span class="repo-name">s20sc/aeros-ecm-library</span>
            <span class="repo-license repo-soon">计划中</span>
          </div>
          <p class="repo-desc">官方 ECM 仓库 — 社区贡献的具身能力模块。</p>
          <div class="repo-tags">
            <span>ECM</span>
            <span>community</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Quick Start ═══ -->
  <section class="section">
    <div class="container">
      <div class="section-label">快速开始</div>
      <h2 class="section-title">60 秒启动并运行</h2>

      <div class="quickstart">
        <div class="terminal">
          <div class="terminal-header">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
            <span class="terminal-title">terminal</span>
          </div>
<pre class="terminal-body"><span class="comment"># 安装 AEROS</span>
<span class="prompt">$</span> <span class="cmd">pip install aeros</span>

<span class="comment"># 运行演示</span>
<span class="prompt">$</span> <span class="cmd">aeros demo</span>
<span class="ok">&#10003; Runtime started on port 8420</span>
<span class="ok">&#10003; Demo agent: arm-sim-01</span>
<span class="ok">&#10003; ECM loaded: pick-and-place@1.0</span>
<span class="ok">&#10003; Governance: sandbox mode</span>
<span class="out">  Open localhost:8420 for dashboard</span>

<span class="comment"># 或探索 CLI</span>
<span class="prompt">$</span> <span class="cmd">aeros --help</span></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Contributing ═══ -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-label">参与贡献</div>
      <h2 class="section-title">参与方式</h2>

      <div class="contrib-grid">
        <div class="contrib-card">
          <h3>编写 ECM</h3>
          <p>构建一个能力模块 — 导航、操作、感知，或任何 Agent 需要的能力。</p>
        </div>
        <div class="contrib-card">
          <h3>添加基准场景</h3>
          <p>为 EmbodiedGovBench 贡献测试场景，用于评估受治理的智能体系统。</p>
        </div>
        <div class="contrib-card">
          <h3>改进文档</h3>
          <p>更好的文档、教程和示例能帮助所有人。每个 PR 都有价值。</p>
        </div>
        <div class="contrib-card">
          <h3>报告问题</h3>
          <p>发现 bug 或有功能建议？在 GitHub 上提交 issue。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Research ═══ -->
  <section class="section">
    <div class="container" style="text-align: center;">
      <div class="section-label">学术基础</div>
      <h2 class="section-title">7 篇系统性论文</h2>
      <p class="section-desc" style="margin: 0 auto var(--space-xl);">
        AEROS 由一个全面的研究计划支撑，涵盖具身智能体系统的运行时架构、治理、进化、契约、联邦化和基准测试。
        所有论文均在 arXiv 上公开发布。
      </p>
      <a href="https://s20sc.github.io/aeros-project" target="_blank" rel="noopener" class="btn btn-primary">
        查看研究计划
      </a>
    </div>
  </section>

</BaseLayout>

<style>
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: var(--space-md);
  }
  .page-desc {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 480px;
    line-height: 1.7;
  }
  .section-alt {
    background: var(--bg-surface);
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }

  /* ═══ Repos ═══ */
  .repo-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }
  .repo-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-base);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    transition: border-color var(--duration-short), transform var(--duration-short);
  }
  .repo-card:hover {
    border-color: rgba(0, 102, 255, 0.3);
    transform: translateY(-2px);
  }
  .repo-planned { opacity: 0.6; }
  .repo-planned:hover { transform: none; border-color: var(--border); }

  .repo-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-sm);
  }
  .repo-name {
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary);
  }
  .repo-license {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 3px 10px;
    border-radius: var(--radius-full);
    background: rgba(0, 102, 255, 0.1);
    color: var(--primary);
  }
  .repo-soon {
    background: rgba(100, 116, 139, 0.1);
    color: var(--text-muted);
  }
  .repo-desc {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.5;
    flex: 1;
    margin-bottom: var(--space-md);
  }
  .repo-tags {
    display: flex;
    gap: var(--space-sm);
  }
  .repo-tags span {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    background: var(--bg-elevated);
    color: var(--text-muted);
  }

  /* ═══ Terminal ═══ */
  .quickstart { max-width: 640px; }
  .terminal {
    background: #0D1117;
    border: 1px solid #21262D;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .terminal-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 10px var(--space-md);
    background: #161B22;
    border-bottom: 1px solid #21262D;
  }
  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot.red { background: #FF5F57; }
  .dot.yellow { background: #FEBC2E; }
  .dot.green { background: #28C840; }
  .terminal-title {
    font-family: var(--font-mono);
    font-size: 12px;
    color: #8B949E;
    margin-left: var(--space-sm);
  }
  .terminal-body {
    padding: var(--space-md) var(--space-lg);
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.8;
    color: #C9D1D9;
    white-space: pre;
    margin: 0;
    overflow-x: auto;
  }
  .prompt { color: var(--secondary); }
  .cmd { color: #F0F6FC; }
  .comment { color: #484F58; }
  .out { color: #8B949E; }
  .ok { color: var(--success); }

  /* ═══ Contributing ═══ */
  .contrib-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }
  .contrib-card {
    background: var(--bg-base);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
  }
  .contrib-card h3 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
  }
  .contrib-card p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .repo-grid, .contrib-grid { grid-template-columns: 1fr; }
  }
</style>
