---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="关于我们 — AEROS" description="AEROS 背后的团队和使命 — 为具身智能体构建可治理的运行时基础设施。" lang="zh">

  <!-- ═══ Mission ═══ -->
  <section class="section" style="padding-bottom: var(--space-2xl);">
    <div class="container">
      <div class="section-label">关于我们</div>
      <h1 class="page-title">
        构建具身智能体<br>应得的基础设施
      </h1>
      <p class="page-desc">
        机器人的未来不仅是更强的模型或更好的硬件。
        关键是谁来定义智能体真正<em>运行</em>的那一层。
      </p>
    </div>
  </section>

  <!-- ═══ Mission Statement ═══ -->
  <section class="section section-alt">
    <div class="container">
      <div class="mission-block">
        <div class="mission-quote">
          <p>
            我们为具身智能体构建可治理、可进化的运行时基础设施。
          </p>
          <p class="mission-sub">
            不是另一个机器人操作系统。不是另一个模型封装。
            而是一个运行时平台，让"AI 演示"到"AI 量产"之间的鸿沟变得可管理、安全且可审计。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Why This Matters ═══ -->
  <section class="section">
    <div class="container">
      <div class="section-label">论点</div>
      <h2 class="section-title">为什么具身智能体需要运行时基础设施</h2>

      <div class="thesis-grid">
        <div class="thesis-card">
          <div class="thesis-num">01</div>
          <h3>模型是必要的但不充分</h3>
          <p>基础模型赋予智能体推理能力。但没有治理、状态管理和生命周期控制的推理，只是演示，不是产品。</p>
        </div>
        <div class="thesis-card">
          <div class="thesis-num">02</div>
          <h3>硬件多样性在加速</h3>
          <p>人形机器人、四足机器人、AMR、无人机、协作臂 — 每种都有不同的能力。能力必须模块化、可移植、可版本化。</p>
        </div>
        <div class="thesis-card">
          <div class="thesis-num">03</div>
          <h3>生产环境需要治理</h3>
          <p>在仓库、医院和公共空间，"发生了什么？"和"谁授权的？"不是可选问题。运行时治理让这些问题有答案。</p>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══ Milestones ═══ -->
  <section class="section">
    <div class="container">
      <div class="section-label">时间线</div>
      <h2 class="section-title">里程碑</h2>

      <div class="timeline">
        <div class="timeline-item done">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <span class="timeline-date">2026.04</span>
            <h3>7 篇研究论文完成</h3>
            <p>系统性学术基础，涵盖运行时、治理、进化、契约、联邦化和基准测试。</p>
          </div>
        </div>
        <div class="timeline-item done">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <span class="timeline-date">2026.04</span>
            <h3>arXiv 预印本发布</h3>
            <p>4 篇论文公开发布，接受同行评审和学术审查。</p>
          </div>
        </div>
        <div class="timeline-item done">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <span class="timeline-date">2026.04</span>
            <h3>AEROS 开源 MVP</h3>
            <p>运行时核心以 Apache 2.0 发布。项目主页上线。</p>
          </div>
        </div>
        <div class="timeline-item active">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <span class="timeline-date">2026.H2</span>
            <h3>运行时核心 v1.0</h3>
            <p>生产就绪的运行时，完整的生命周期管理、ECM 支持和追踪。</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <span class="timeline-date">2026.H2</span>
            <h3>首个试点部署</h3>
            <p>与仓储自动化合作伙伴的概念验证部署。</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <span class="timeline-date">2027</span>
            <h3>治理控制台上线</h3>
            <p>面向企业的治理产品，用于车队级策略执行和审计。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Investor CTA ═══ -->
  <section class="section section-alt" style="text-align: center;">
    <div class="container">
      <h2 class="section-title">致投资人</h2>
      <p class="section-desc" style="margin: 0 auto var(--space-xl);">
        AEROS 正在定义具身 AI 的运行时层 — 一个尚不存在的品类。
        我们正在寻找理解基础设施级投资的合作伙伴。
      </p>
      <div style="display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap;">
        <a href="/zh/contact" class="btn btn-primary">预约沟通</a>
        <a href="/zh/contact" class="btn btn-secondary">索取 BP</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    margin-bottom: var(--space-md);
  }
  .page-title em { font-style: normal; color: var(--primary); }
  .page-desc {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 560px;
    line-height: 1.7;
  }
  .page-desc em { font-style: normal; color: var(--primary); font-weight: 600; }
  .section-alt {
    background: var(--bg-surface);
    border-top: 1px solid var(--border-subtle);
    border-bottom: 1px solid var(--border-subtle);
  }

  /* ═══ Mission ═══ */
  .mission-block {
    max-width: 720px;
  }
  .mission-quote p {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
    margin-bottom: var(--space-lg);
  }
  .mission-sub {
    font-family: var(--font-body) !important;
    font-size: 1rem !important;
    font-weight: 400 !important;
    color: var(--text-secondary) !important;
    line-height: 1.7 !important;
  }

  /* ═══ Thesis ═══ */
  .thesis-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }
  .thesis-card {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }
  .thesis-num {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--primary);
    margin-bottom: var(--space-md);
  }
  .thesis-card h3 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
    line-height: 1.3;
  }
  .thesis-card p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  /* ═══ Team ═══ */
  .team-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }
  .team-card {
    display: flex;
    gap: var(--space-xl);
    background: var(--bg-base);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    align-items: start;
  }
  .team-avatar {
    width: 72px;
    height: 72px;
    border-radius: var(--radius-lg);
    background: rgba(0, 102, 255, 0.1);
    color: var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .team-info h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 2px;
  }
  .team-role {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--primary);
    margin-bottom: var(--space-md);
  }
  .team-bio {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .team-hiring {
    font-size: 14px;
    color: var(--text-muted);
    padding: var(--space-md) var(--space-lg);
    background: var(--bg-base);
    border: 1px dashed var(--border);
    border-radius: var(--radius-md);
  }
  .team-hiring a {
    color: var(--primary);
    font-weight: 500;
  }

  /* ═══ Timeline ═══ */
  .timeline {
    max-width: 640px;
    position: relative;
    padding-left: var(--space-xl);
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--border);
  }
  .timeline-item {
    position: relative;
    padding-bottom: var(--space-xl);
  }
  .timeline-item:last-child { padding-bottom: 0; }

  .timeline-marker {
    position: absolute;
    left: calc(-1 * var(--space-xl) + 2px);
    top: 6px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--bg-base);
    border: 2px solid var(--border);
  }
  .done .timeline-marker {
    background: var(--success);
    border-color: var(--success);
  }
  .active .timeline-marker {
    background: var(--primary);
    border-color: var(--primary);
    box-shadow: 0 0 0 4px rgba(0, 102, 255, 0.2);
  }

  .timeline-date {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
  }
  .timeline-content h3 {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: var(--space-xs) 0;
  }
  .timeline-content p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  .timeline-item:not(.done):not(.active) h3 { color: var(--text-muted); }
  .timeline-item:not(.done):not(.active) p { color: var(--text-muted); }

  @media (max-width: 768px) {
    .thesis-grid { grid-template-columns: 1fr; }
    .team-card { flex-direction: column; }
  }
</style>
